{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "formstand": ["../src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"],
  // Personal scratch space (gitignored, see the root .gitignore): sketches
  // there may be pseudocode and must not gate the build.
  "exclude": ["src/recipes"]
}
